{
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "installCommand": null,
  "functions": {
    "api/chat.js": { "runtime": "nodejs20.x" }
  },
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/chat.html", "dest": "/chat.html" },
    { "src": "/(.*)",      "dest": "/$1" }
  ]
}
